# Unzipped Vivado project + runs (regenerate from Au2_SLI.zip; build via build/build_uart.tcl)
/build/

# Vivado transient files
*.jou
*.log
.Xil/
vivado_*.str
*.str

# Internal planning doc — keep out of the public repo
AlchitryFlasher/CAMERA_USB_PLAN.md

# Vivado build outputs / scratch (stale qishi-hu build dir + run reports)
build_au2/
*.rpt
clockInfo.txt
dfx_runtime.txt
tight_setup_hold_pins.txt

# KiCad caches / local / transient files
fp-info-cache
*.kicad_prl
*-backups/
*.lck
~*.lck
.history/

# 3D STEP exports for the stacking board (regenerable; the Br stack assembly is ~52 MB).
# Source 3D models in 3dmodels/ are kept - they are needed to regenerate the export.
/LauCameraTrigger_Alchitry_Stack/*.step
/LauCameraTrigger_Alchitry_Stack/*.stp

# Editor / IDE local files - keep only FPGA + PCB source in the repo
.qtcreator/
*.user
*.user.*
CMakeLists.txt.user*
.vscode/
.idea/
*.autosave

# KiCad backups
*.kicad_sch.bak*
*.kicad_pcb.bak*
*-backups/

# Third-party reference material -- fetched locally, NOT redistributed.
# This repo is public; see CAMERA_SENSOR_PROTOCOL.md §8 to re-fetch.
#   - docs/datasheets/  : onsemi datasheet PDF + text extract (onsemi copyright)
#   - docs/reference/   : Avnet driver source ("Publication of this design is not
#                         authorized without written consent from Avnet"), and
#                         osrf/ovc HDL (Apache-2.0, but the files carry no header)
docs/datasheets/
docs/reference/

# IP simulation artifacts dropped in the root by build.tcl
*.mif
